# ── Backend env (скопируй в .env и заполни) ──
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT (64+ символов; refresh — отдельный секрет)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1h

# Postgres
DB_URL=postgresql://user:password@host:port/dbname

# Cloudinary — только имя аккаунта (загрузка идёт с фронта, unsigned)
CLOUDINARY_CLOUD_NAME=

# Email (Resend). Пусто = dev-режим: ссылки печатаются в консоль
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Отдельная БД для автотестов (vitest). Должна содержать "polish_test" в имени
TEST_DATABASE_URL=postgresql://user:password@host:port/polish_test

# Мониторинг ошибок Sentry (пусто = выключено)
SENTRY_DSN=

# AI-генератор тестов (OpenAI-совместимый провайдер). Пусто = 503 «AI не настроен».
# По умолчанию — Groq (бесплатно): ключ на console.groq.com
AI_API_KEY=
# Необязательно (это дефолты — Groq + Llama 3.3 70B):
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile
